# Backblaze B2 (required)
B2_ENDPOINT=your_b2_endpoint
B2_REGION=your_b2_region
B2_APPLICATION_KEY_ID=your_application_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name

# --- Trainer (optional) — default "simulated" needs no GPU and no keys ---
# Selects the Trainer adapter. "local" runs a real Stable Diffusion 1.5 LoRA
# fine-tune on-device (GPU/Apple-Silicon MPS); first install the ML stack with
#   pip install -r services/api/requirements-local-trainer.txt
# "replicate" is a not-wired cloud stub behind REPLICATE_API_TOKEN.
# TRAINER_PROVIDER=local
# REPLICATE_API_TOKEN=your_replicate_token

# Local (real) trainer tuning — only used when TRAINER_PROVIDER=local.
# Values below are the defaults; uncomment to override.
# LOCAL_SD_MODEL_ID=stable-diffusion-v1-5/stable-diffusion-v1-5
# LOCAL_TRAIN_RESOLUTION=512
# LOCAL_MILESTONES=4
# LOCAL_SAMPLES_PER_MILESTONE=4

# --- Captioner (optional) — default "templated" is offline, needs no keys ---
# Set to "claude" to auto-caption with Claude vision (requires ANTHROPIC_API_KEY).
# CAPTIONER_PROVIDER=claude
# ANTHROPIC_API_KEY=your_anthropic_key
# CLAUDE_CAPTION_MODEL=claude-haiku-4-5

# Example of what filled-in values look like (fake — for visual reference only):
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_REGION=us-west-004
# B2_APPLICATION_KEY_ID=00abcdef1234567000000001
# B2_APPLICATION_KEY=K001AbCdEfGhIjKlMnOpQrStUvWxYz0=
# B2_BUCKET_NAME=my-app-uploads
